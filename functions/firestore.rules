rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    match /passes/{id} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /logs/{id} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /users/{id} {
      allow read: if request.auth.uid == id;
      allow write: if false;
    }
  }
}